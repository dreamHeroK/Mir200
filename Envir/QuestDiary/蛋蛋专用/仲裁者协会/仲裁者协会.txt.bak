#OR
SMALL <$STR(N$玩家等级)> 50
EQUAL N$排行榜数值 0
#ACT
TextLength 无人上榜 N$当前字符串长度
MOV N$基准坐标 <$STR(N$坐标X)>
MOV N$基准长度 0

DEC N$基准长度 <$STR(N$当前字符串长度)>
MUL N$基准长度 6
DIV N$基准长度 2
MOV N$坐标 <$STR(N$基准坐标)>
INC N$坐标 <$STR(N$基准长度)>

MOV S$排行榜名字显示<$STR(N$操作序号)> <TEXT:无人上榜:<$STR(N$坐标)>:<$STR(N$坐标Y)>/FCOLOR=7>

TextLength 0 N$当前字符串长度
MOV N$基准坐标 <$STR(N$坐标X)>
MOV N$基准长度 0

DEC N$基准长度 <$STR(N$当前字符串长度)>
MUL N$基准长度 6
DIV N$基准长度 2
MOV N$坐标 <$STR(N$基准坐标)>
INC N$坐标 <$STR(N$基准长度)>

MOV S$排行榜数值显示<$STR(N$操作序号)> <TEXT:0:<$STR(N$坐标)>:<$STR(N$坐标Y)>/FCOLOR=7>

INC N$坐标X 0
INC N$坐标Y -60

TextLength <$STR(S$标识)>榜 N$当前字符串长度
MOV N$基准坐标 <$STR(N$坐标X)>
MOV N$基准长度 0

DEC N$基准长度 <$STR(N$当前字符串长度)>
MUL N$基准长度 6
DIV N$基准长度 2
MOV N$坐标 <$STR(N$基准坐标)>
INC N$坐标 <$STR(N$基准长度)>

MOV S$排行榜职业显示<$STR(N$操作序号)> <TEXT:<$STR(S$标识)>.No1:<$STR(N$坐标)>:<$STR(N$坐标Y)>/FCOLOR=7>


BREAK

#IF
NOT SMALL <$STR(N$玩家等级)> 50
LARGE N$排行榜数值 0
#ACT
TextLength <$STR(S$当前名字)> N$当前字符串长度
