INC N$坐标 <$STR(N$基准长度)>

MOV S$排行榜数值显示<$STR(N$操作序号)> <TEXT:<$STR(N$排行榜数值)>:<$STR(N$坐标)>:<$STR(N$坐标Y)>/FCOLOR=251>

INC N$坐标X 0
INC N$坐标Y -60

TextLength <$STR(S$标识)>榜 N$当前字符串长度
MOV N$基准坐标 <$STR(N$坐标X)>
MOV N$基准长度 0

DEC N$基准长度 <$STR(N$当前字符串长度)>
MUL N$基准长度 6
DIV N$基准长度 2
